# LLM API Configuration
# Copy this file to .env and fill in your values

# LLM API Base URL (e.g., https://api.openai.com/v1 or your custom endpoint)
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Your API Key
LLM_API_KEY=your-api-key-here

# Model ID (e.g., gpt-4, gpt-3.5-turbo, or your custom model)
LLM_MODEL_ID=gpt-4