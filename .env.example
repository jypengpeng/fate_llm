# LLM API Configuration
# Copy this file to .env and fill in your values

# API format switch: openai | gemini
# - openai: OpenAI-compatible /v1/chat/completions format
# - gemini: Google Gemini generateContent format
LLM_API_FORMAT=openai

# LLM API Base URL (e.g., https://api.openai.com/v1 or your custom endpoint)
# OpenAI-compatible example:
LLM_API_URL=https://api.openai.com/v1/chat/completions
# Gemini example (with placeholders):
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={api_key}

# Your API Key
LLM_API_KEY=your-api-key-here

# Model ID (e.g., gpt-4, gpt-3.5-turbo, gemini-1.5-pro, gemini-2.0-flash)
LLM_MODEL_ID=gpt-4
